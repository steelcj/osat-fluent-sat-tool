#!/usr/bin/env bash
# ~/.local/bin/{command}
# Generated by {manager}. Do not edit; regenerated on --install and --switch.
# Sources {env_file} at runtime, so version switching requires no shell restart
# and non-interactive contexts (systemd timers, cron) resolve the same version.
. "$HOME/.config/sat-tool/sat-tool.env"
exec "$SAT_TOOL_ROOT/{dispatcher}" "$@"
